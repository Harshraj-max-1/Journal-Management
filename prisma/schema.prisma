generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  AUTHOR
  PUBLISHER
  EDITOR
  ADMIN
  READER
}

enum PaperStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  PUBLISHED
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  password      String?         // Optional for OAuth users
  role          Role           @default(READER)
  createdAt     DateTime       @default(now())
  
  accounts      Account[]
  sessions      Session[]
  papers        Paper[]        @relation("PaperAuthor")
  reviews       Review[]       @relation("ReviewAuthor")
  notifications Notification[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Paper {
  id               String      @id @default(cuid())
  // Original Author Version
  originalTitle    String
  originalAbstract String
  originalFileUrl  String?
  
  // Editor Redined Version
  editedTitle      String?
  editedAbstract   String?
  editedFileUrl    String?
  editorNotes      String?     @db.Text
  
  // Legacy fields (for compatibility)
  title            String      // Current working title
  abstract         String      // Current working abstract
  fileUrl          String?     // Current working file
  
  status           PaperStatus @default(DRAFT)
  
  authorId         String
  author           User        @relation("PaperAuthor", fields: [authorId], references: [id])
  
  coAuthors        String[]    @default([])
  
  reviews          Review[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  paperId     String
  paper       Paper    @relation(fields: [paperId], references: [id])
  
  publisherId String
  publisher   User     @relation("ReviewAuthor", fields: [publisherId], references: [id])
  
  comments    String   @db.Text
  rating      Int
  decision    String
  createdAt   DateTime @default(now())
}

model Category {
  id   String @id @default(cuid())
  name String @unique
}

model JournalIssue {
  id          String    @id @default(cuid())
  title       String
  volume      Int
  issue       Int
  description String?
  publishedAt DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
